{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DIRECTUS_URL",
    "DIRECTUS_PUBLIC_TOKEN",
    "DIRECTUS_ADMIN_TOKEN",
    "NEXT_PUBLIC_VERSION",
    "CMS_TOKEN",
    "GOOGLE_ANALYTICS_ID",
    "SENTRY_AUTH_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist", ".strapi"]
    },
    "seed:sample": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "schema:pull": {
      "persistent": true
    },
    "schema:push": {
      "persistent": true
    },
    "schema:push:dev": {
      "persistent": true
    },
    "schema:push:live": {
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "api": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "start": {
      "dependsOn": ["^build"]
    },
    "coverage": {
      "dependsOn": ["^build"]
    },
    "seed:dev": {
      "cache": false
    },
    "generate:types": {
      "cache": false
    },
    "e2e": {
      "cache": false,
      "persistent": false
    }
  }
}
