{
  "name": "@pkrbt/schema",
  "version": "0.0.0-development",
  "description": "Directus Schema",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prebuild": "npm run cleanup",
    "cleanup": "rimraf ./dist",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "api": "node ./bin/api.mjs",
    "schema:pull": "npx directus-sync pull",
    "schema:push:local": "npx directus-sync push",
    "schema:push": "npx directus-sync -c directus-sync.target.js push"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@directus/sdk": "^17.0.2",
    "@pkrbt/typescript-config": "workspace:*",
    "@types/dotenv": "^8.2.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.1",
    "vitest-mock-extended": "^2.0.2"
  }
}
