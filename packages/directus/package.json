{
  "name": "@pkrbt/directus",
  "version": "0.0.0-development",
  "description": "PKRBT Directus Utils",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "pwa": "tsup src/index.ts --format cjs,esm --dts --watch",
    "generate:types": "node ./scripts/download.mjs && openapi-typescript ./scripts/downloads/openapi.json -o src/types/openapi.ts",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest --coverage"
  },
  "keywords": [],
  "author": "PKRBT Developers",
  "license": "MIT",
  "devDependencies": {
    "@pkrbt/eslint-config": "workspace:*",
    "@pkrbt/typescript-config": "workspace:*",
    "@types/eslint": "^8",
    "@vitest/coverage-v8": "^2.1.1",
    "dotenv": "^16.4.5",
    "eslint": "^8",
    "openapi-typescript": "^7.4.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "dependencies": {
    "@directus/sdk": "^17.0.2",
    "openapi-fetch": "^0.12.2",
    "tiny-invariant": "^1.3.3"
  }
}
